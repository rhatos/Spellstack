  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A World Shattered\n\r\nThe elemental pillars that once protected Vital\xE9
    have been destroyed by a goblin cult, their power stolen to resurrect a Great
    Evil. You are Arwen, the only person left who remembers the ancient ways of magic.\r\n\r\nMaster
    the Elements\n\r\nIn a world that has forgotten magic, you must reclaim it. Since
    you are still learning, you cannot rely on a single element alone. To survive,
    you must weave remnants of Fire, Water, Air, and Earth into devastating combinations.\r\n\r\nMerge
    elemental spells to overcome the Dark Wizard\u2019s captains. Weave the elements.
    Break the cult. Become the High Mage."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
